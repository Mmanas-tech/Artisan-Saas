{
  "name": "artisan-saas",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:migrate": "cd packages/db && npm run migrate",
    "db:seed": "cd packages/db && npm run seed",
    "api:dev": "turbo dev --filter=@artisan/api",
    "mobile:dev": "turbo dev --filter=@artisan/mobile",
    "web:dev": "turbo dev --filter=@artisan/web"
  },
  "devDependencies": {
    "turbo": "^2.10.1",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.13.0"
}
